# Copy to project root as `.env` for docker compose:
#   cp deploy/server.env.example .env
#   или готовый вариант: cp deploy/server.env .env

# Host:container — один и тот же номер (например 3030:3030), gateway слушает HTTP на этом порту.
PUBLIC_PORT=3030

# Webapp (static nginx inside `webapp` image)
WEBAPP_PORT=8080

# Internal data API listens on 8787 inside the Docker network (must match deploy/default.conf.template).
INTERNAL_DATA_HOST=0.0.0.0
INTERNAL_DATA_DIR=/data

# --- Vite build args for `webapp` ---
# internal: только каталог internal-data на сервере, без Яндекс.Облака.
# yandex: Excel с публичной папки — запросы к Яндексу выполняет internal-data-api (ПК в LAN может быть без интернета).
# true: браузер может ходить в интернет (Nominatim и т.д.). false: карта/тайлы всё равно грузятся через /api на сервере — VPN на ПК не нужен, но контейнер internal-data-api должен выходить в интернет (Carto, Esri, frexosm, Яндекс).
VITE_ENABLE_EXTERNAL_NETWORK=true
VITE_DATA_SOURCE=yandex
VITE_INTERNAL_DATA_API_BASE=/api
# Ссылка на публичную папку Яндекс.Диска (при необходимости замените на свою).
# VITE_YANDEX_PUBLIC_KEY=https://disk.yandex.ru/d/...
# satellite | vector | basin | local — vector/basin используют /api/map/fetch и /api/tiles/* на сервере.
VITE_MAP_DEFAULT_TYPE=satellite
VITE_MAP_SATELLITE_TILES_URL=
VITE_MAP_VECTOR_STYLE_URL=
VITE_MAP_BASIN_STYLE_URL=/frexosm_basin_style.json
# Без локальных /tiles и /fonts: префикс для относительных URL в стиле бассейнов (тайлы, глифы, рельеф).
VITE_MAP_ASSETS_BASE=https://frexosm.ru
VITE_NOMINATIM_ENABLED=false
VITE_NOMINATIM_URL=
