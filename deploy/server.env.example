# Copy to project root as `.env` for docker compose:
#   cp deploy/server.env.example .env

# Published HTTPS port (host). Use 443 in production; 8443 if 443 is busy locally.
PUBLIC_PORT=443

# Webapp (static nginx inside `webapp` image)
WEBAPP_PORT=8080

# Internal data API listens on 8787 inside the Docker network (must match deploy/nginx.conf).
INTERNAL_DATA_HOST=0.0.0.0
INTERNAL_DATA_DIR=/data

# --- Vite build args for `webapp` (closed network defaults) ---
VITE_ENABLE_EXTERNAL_NETWORK=false
VITE_DATA_SOURCE=internal
VITE_INTERNAL_DATA_API_BASE=/api
VITE_MAP_DEFAULT_TYPE=local
VITE_MAP_SATELLITE_TILES_URL=
VITE_MAP_VECTOR_STYLE_URL=
VITE_MAP_BASIN_STYLE_URL=/frexosm_basin_style.json
VITE_NOMINATIM_ENABLED=false
VITE_NOMINATIM_URL=
