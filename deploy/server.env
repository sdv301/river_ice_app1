# Скопируйте в корень проекта как `.env` на сервере:
#   cp deploy/server.env .env
# Или: docker compose --env-file deploy/server.env up -d
#
# Важно: compose подставляет переменные из файла `.env` в ТОМ ЖЕ каталоге, что и docker-compose.yml.
# Без этого используется значение по умолчанию из docker-compose.yml (PUBLIC_PORT=3030).

PUBLIC_PORT=3030
WEBAPP_PORT=8080
INTERNAL_DATA_HOST=0.0.0.0
INTERNAL_DATA_DIR=/data

VITE_ENABLE_EXTERNAL_NETWORK=false
VITE_DATA_SOURCE=internal
VITE_INTERNAL_DATA_API_BASE=/api
VITE_MAP_DEFAULT_TYPE=local
VITE_MAP_SATELLITE_TILES_URL=
VITE_MAP_VECTOR_STYLE_URL=
VITE_MAP_BASIN_STYLE_URL=/frexosm_basin_style.json
VITE_NOMINATIM_ENABLED=false
VITE_NOMINATIM_URL=
