FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci && npm cache clean --force

COPY server ./server

ENV INTERNAL_DATA_HOST=0.0.0.0
ENV INTERNAL_DATA_PORT=8787
ENV INTERNAL_DATA_DIR=/data

EXPOSE 8787

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD wget -q -O /dev/null http://127.0.0.1:8787/api/health || exit 1

CMD ["npx", "tsx", "server/internalDataApi.ts"]
