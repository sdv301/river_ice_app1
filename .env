# Docker Compose читает этот файл из корня (рядом с docker-compose.yml).
# Шаблон: deploy/docker.env
PUBLIC_PORT=3030
WEBAPP_PORT=8080

INTERNAL_DATA_HOST=0.0.0.0
INTERNAL_DATA_DIR=/data
INTERNAL_DATA_SYNC_DIR=/cache

VITE_ENABLE_EXTERNAL_NETWORK=true
VITE_DATA_SOURCE=internal
VITE_INTERNAL_DATA_API_BASE=/api
VITE_MAP_DEFAULT_TYPE=satellite
VITE_MAP_SATELLITE_TILES_URL=/api/tiles/arcgis/{z}/{y}/{x}
VITE_MAP_VECTOR_STYLE_URL=https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json
VITE_MAP_BASIN_STYLE_URL=/frexosm_basin_style.json
VITE_MAP_ASSETS_BASE=https://frexosm.ru
VITE_NOMINATIM_ENABLED=false

YANDEX_PUBLIC_KEY=https://disk.yandex.ru/d/LENyBdYBr2B3rA
VITE_YANDEX_PUBLIC_KEY=https://disk.yandex.ru/d/LENyBdYBr2B3rA
